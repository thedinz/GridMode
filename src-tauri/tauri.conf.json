{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GridMode",
  "version": "0.1.9",
  "identifier": "com.thedinz.gridmode",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm build:renderer"
  },
  "app": {
    "windows": [
      {
        "title": "GridMode",
        "width": 1320,
        "height": 920,
        "minWidth": 840,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost gridmode-photo: http://gridmode-photo.localhost https://gridmode-photo.localhost blob: data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "thedinz",
    "homepage": "https://github.com/thedinz/GridMode",
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
