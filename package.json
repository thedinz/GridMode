{
  "name": "gridmode",
  "version": "0.1.9",
  "description": "GridMode is a desktop photo viewer built around your folders, EXIF dates, and fast visual wandering.",
  "author": "thedinz",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "tauri dev",
    "build": "pnpm build:renderer",
    "build:renderer": "tsc -p tsconfig.renderer.json && vite build",
    "typecheck": "tsc -p tsconfig.renderer.json --pretty",
    "dist": "tauri build",
    "dist:win": "tauri build --bundles nsis",
    "dist:mac": "tauri build --bundles dmg",
    "release:win": "pnpm dist:win && node scripts/create-electron-updater-yml.mjs",
    "stamp-version": "node scripts/stamp-version.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  }
}
