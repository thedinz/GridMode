{
  "name": "gridmode",
  "version": "0.1.8",
  "description": "GridMode is a desktop photo viewer built around your folders, EXIF dates, and fast visual wandering.",
  "author": "thedinz",
  "license": "MIT",
  "main": "dist/main/main.js",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on dist/main/main.js http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:renderer": "tsc -p tsconfig.renderer.json && vite build",
    "typecheck": "tsc -b --pretty",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win nsis",
    "dist:mac": "pnpm build && electron-builder --mac dmg zip --x64 --publish never",
    "release:win": "pnpm build && electron-builder --win nsis --publish always",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "electron-updater": "^6.6.2",
    "exifr": "^7.1.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.thedinz.gridmode",
    "productName": "GridMode",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "artifactName": "GridMode-${version}-mac-${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "GridMode-Setup-${version}.${ext}"
    },
    "nsis": {
      "guid": "2be86298-0152-5856-866e-d6a567f160b7",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "GridMode",
      "uninstallDisplayName": "GridMode"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "thedinz",
        "repo": "GridMode",
        "releaseType": "release"
      }
    ]
  }
}
